# ---- Panel ----
# Port Railway assigns publicly (Railway sets this automatically; keep default for local testing)
PORT=8080

# Secret key required in the "X-API-Key" header for every /api/* request.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
API_KEY=change-me-to-a-long-random-string

# Username/password for the simple web dashboard (Basic Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-too

# Public domain Railway gives your service (Settings -> Networking -> Public Domain),
# e.g. my-vpn-panel.up.railway.app -- used to build client connection links.
PANEL_DOMAIN=your-app.up.railway.app

# ---- VPN transport ----
# The URL path clients connect to over WebSocket. Keep it long & random so it
# is not guessable by port scanners (this is your only "secret" on the wire
# since Railway terminates TLS for you).
VLESS_WS_PATH=/xr-9f2a1c4e

# Local port Xray listens on (never exposed publicly, only proxied internally)
XRAY_LOCAL_PORT=10800

# Local port for Xray's gRPC API (stats/handler), also internal-only
XRAY_API_PORT=10085

# Path to the xray-core binary inside the container
XRAY_BIN=/usr/local/bin/xray

# Path where the panel writes the live Xray config
XRAY_CONFIG_PATH=/app/data/xray-config.json

# How often (ms) the panel polls Xray for per-user traffic and enforces
# expiry/quota limits
STATS_INTERVAL_MS=60000

# ---- SQLite ----
DB_PATH=/app/data/panel.db
